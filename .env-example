# Beispiel-Konfiguration. Kopiere diese Datei nach `.env` und trage echte Werte
# ein. `.env` ist per .gitignore ausgeschlossen und darf NICHT committet werden.

# --- Logging ---
# Log-Level: debug | info | warn | error  (Standard: info)
LOG_LEVEL=info

# --- PostgreSQL (M164) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=codera
DB_USER=codera
DB_PASSWORD=codera
DB_SSLMODE=disable
